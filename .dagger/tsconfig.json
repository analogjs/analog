{
  "compilerOptions": {
    "target": "ES2022",
    "moduleResolution": "Node",
    "module": "ES2022",
    "experimentalDecorators": true,
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "outDir": "dist",
    "paths": {
      "@dagger.io/dagger": ["./sdk/index.ts"],
      "@dagger.io/dagger/telemetry": ["./sdk/telemetry.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
