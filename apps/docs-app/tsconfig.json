{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "types": ["node", "@docusaurus/module-type-aliases"],
    "paths": {
      "@site/*": ["./*"]
    }
  }
}
