{
  "name": "analog-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/analog-app/src",
  "prefix": "analogjs",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "dependsOn": ["platform:build", "router:build"],
      "outputs": [
        "{options.outputPath}",
        "{workspaceRoot}/dist/apps/analog-app/.nitro",
        "{workspaceRoot}/dist/apps/analog-app/ssr",
        "{workspaceRoot}/dist/apps/analog-app/analog"
      ],
      "options": {
        "configFile": "apps/analog-app/vite.config.ts",
        "outputPath": "dist/apps/analog-app/client"
      },
      "defaultConfiguration": "production",
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "sourcemap": false,
          "mode": "production"
        }
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "dependsOn": ["platform:build", "router:build"],
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "analog-app:build",
        "buildLibsFromSource": true,
        "port": 43000
      },
      "configurations": {
        "development": {
          "buildTarget": "analog-app:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "analog-app:build:production"
        }
      }
    },
    "serve-nitro": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "dist/apps/analog-app/analog",
        "command": "node --unhandled-rejections=throw ./server/index.mjs",
        "env": {
          "PORT": "43000"
        }
      },
      "dependsOn": ["build"]
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "analog-app:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["platform:build", "router:build"],
      "outputs": ["{projectRoot}/coverage"]
    },
    "storybook": {
      "executor": "@analogjs/storybook-angular:start-storybook",
      "dependsOn": ["^build"],
      "options": {
        "configDir": "apps/analog-app/.storybook",
        "compodoc": false,
        "compodocArgs": ["-e", "json", "-d", "."],
        "port": 43050,
        "styles": ["apps/analog-app/src/styles.css"],
        "stylePreprocessorOptions": {
          "loadPaths": []
        }
      }
    },
    "build-storybook": {
      "executor": "@analogjs/storybook-angular:build-storybook",
      "options": {
        "configDir": "apps/analog-app/.storybook",
        "compodoc": false,
        "compodocArgs": ["-e", "json", "-d", "."],
        "outputDir": "dist/apps/storybook-static",
        "styles": ["apps/analog-app/src/styles.css"],
        "stylePreprocessorOptions": {
          "loadPaths": []
        }
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/analog-app",
        "command": "pnpm exec tsgo -p tsconfig.app.json --noEmit"
      }
    }
  }
}
