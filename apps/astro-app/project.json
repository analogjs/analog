{
  "name": "astro-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/astro-app/src",
  "tags": [],
  "targets": {
    "serve": {
      "command": "astro dev --root apps/astro-app --port 43030"
    },
    "build": {
      "command": "astro build --root apps/astro-app",
      "dependsOn": ["astro-angular:build"]
    },
    "preview": {
      "command": "astro preview --root apps/astro-app --port 43030"
    }
  }
}
