{
  "name": "analog-app-e2e-cypress",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/analog-app-e2e-cypress/src",
  "projectType": "application",
  "tags": [],
  "implicitDependencies": ["analog-app"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "start-server-and-test 'nx run analog-app:serve-nitro' http://localhost:3000 'pnpm exec cypress run --project apps/analog-app-e2e-cypress --config-file cypress.config.ts --config baseUrl=http://localhost:3000'"
      },
      "configurations": {
        "watch": {
          "watch": true
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
