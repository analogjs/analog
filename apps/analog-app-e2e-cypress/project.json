{
  "name": "analog-app-e2e-cypress",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/analog-app-e2e-cypress/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "cypress": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "sh -c \"pnpm exec cypress verify || pnpm exec cypress install\"",
          "pnpm exec cypress run --project apps/analog-app-e2e-cypress --config-file cypress.config.ts --config baseUrl=http://localhost:43000"
        ],
        "parallel": false
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "dependsOn": ["analog-app:build"],
      "options": {
        "command": "start-server-and-test 'PORT=43000 node dist/apps/analog-app/analog/server/index.mjs' http://localhost:43000 'nx run analog-app-e2e-cypress:cypress'"
      },
      "configurations": {
        "watch": {
          "watch": true
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
