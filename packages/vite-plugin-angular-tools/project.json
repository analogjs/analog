{
  "name": "vite-plugin-angular-tools",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vite-plugin-angular-tools/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [
        "{workspaceRoot}/packages/vite-plugin-angular/dist/src/lib/tools"
      ],
      "options": {
        "command": "vite build -c packages/vite-plugin-angular-tools/vite.config.lib.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test"
    }
  }
}
