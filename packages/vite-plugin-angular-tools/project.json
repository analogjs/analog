{
  "name": "vite-plugin-angular-tools",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vite-plugin-angular-tools/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [
        "{workspaceRoot}/node_modules/@analogjs/vite-plugin-angular/src/lib/tools"
      ],
      "options": {
        "commands": [
          "vite build packages/vite-plugin-angular-tools",
          "tsc --project packages/vite-plugin-angular-tools/tsconfig.lib.json --emitDeclarationOnly --rootDir packages/vite-plugin-angular-tools --outDir node_modules/@analogjs/vite-plugin-angular/src/lib/tools",
          "node tools/scripts/copy-src-assets.mts packages/vite-plugin-angular-tools node_modules/@analogjs/vite-plugin-angular/src/lib/tools --assets package.json builders.json --src"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test"
    }
  }
}
