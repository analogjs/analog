{
  "name": "cross-utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cross-utils/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build -c packages/cross-utils/vite.config.lib.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/packages/cross-utils"],
      "options": {
        "passWithNoTests": true,
        "reportsDirectory": "{projectRoot}/../../coverage/packages/cross-utils"
      }
    }
  }
}
