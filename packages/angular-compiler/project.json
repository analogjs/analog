{
  "name": "angular-compiler",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/angular-compiler/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build-self": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build --config packages/angular-compiler/vite.config.lib.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build-self"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "node tools/scripts/verify-package-artifacts.mts angular-compiler"
      }
    },
    "test": {
      "executor": "@nx/vitest:test"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/angular-compiler",
        "command": "pnpm exec tsgo --build tsconfig.lib.json --emitDeclarationOnly"
      }
    }
  }
}
