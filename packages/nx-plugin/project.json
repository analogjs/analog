{
  "name": "nx-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/nx-plugin/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [
        "{workspaceRoot}/node_modules/@analogjs/platform/src/lib/nx-plugin"
      ],
      "options": {
        "commands": [
          "vite build packages/nx-plugin",
          "tsc --project packages/nx-plugin/tsconfig.lib.json --emitDeclarationOnly --rootDir packages/nx-plugin --outDir node_modules/@analogjs/platform/src/lib/nx-plugin",
          "node tools/scripts/copy-src-assets.mts packages/nx-plugin node_modules/@analogjs/platform/src/lib/nx-plugin --assets package.json generators.json executors.json --src"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test"
    }
  }
}
