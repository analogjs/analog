{
  "name": "nx-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/nx-plugin/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["platform:build-self"],
      "outputs": ["{workspaceRoot}/packages/platform/dist/src/lib/nx-plugin"],
      "options": {
        "command": "vite build -c packages/nx-plugin/vite.config.lib.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/nx-plugin",
        "command": "pnpm exec tsgo --build tsconfig.lib.json --emitDeclarationOnly"
      }
    }
  }
}
