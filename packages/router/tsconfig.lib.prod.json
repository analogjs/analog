{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "declarationMap": false,
    "target": "ES2022",
    "useDefineForClassFields": false
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  },
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/test-setup.ts",
    "vite.config.ts",
    "vite.config.lib.ts",
    "oxlint.config.ts"
  ],
  "include": ["**/*.ts"]
}
