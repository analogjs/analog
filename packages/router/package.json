{
  "name": "@analogjs/router",
  "version": "3.0.0-alpha.18",
  "description": "Filesystem-based routing for Angular",
  "type": "module",
  "author": "Brandon Roberts <robertsbt@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/fesm2022/analogjs-router.mjs",
      "default": "./dist/fesm2022/analogjs-router.mjs"
    },
    "./content": {
      "types": "./dist/types/content/src/index.d.ts",
      "import": "./dist/fesm2022/analogjs-router-content.mjs",
      "default": "./dist/fesm2022/analogjs-router-content.mjs"
    },
    "./tanstack-query": {
      "types": "./dist/types/tanstack-query/src/index.d.ts",
      "import": "./dist/fesm2022/analogjs-router-tanstack-query.mjs",
      "default": "./dist/fesm2022/analogjs-router-tanstack-query.mjs"
    },
    "./server": {
      "types": "./dist/types/server/src/index.d.ts",
      "import": "./dist/fesm2022/analogjs-router-server.mjs",
      "default": "./dist/fesm2022/analogjs-router-server.mjs"
    },
    "./server/actions": {
      "types": "./dist/types/server/actions/src/index.d.ts",
      "import": "./dist/fesm2022/analogjs-router-server-actions.mjs",
      "default": "./dist/fesm2022/analogjs-router-server-actions.mjs"
    },
    "./tokens": {
      "types": "./dist/types/tokens/src/index.d.ts",
      "import": "./dist/fesm2022/analogjs-router-tokens.mjs",
      "default": "./dist/fesm2022/analogjs-router-tokens.mjs"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "keywords": [
    "angular",
    "router",
    "filesystem-routing",
    "meta-framework"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/analogjs/analog/issues"
  },
  "homepage": "https://analogjs.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/analogjs/analog.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/brandonroberts"
  },
  "peerDependencies": {
    "@analogjs/content": "workspace:*",
    "@angular/core": "catalog:peerCompat",
    "@angular/platform-server": "catalog:peerCompat",
    "@angular/router": "catalog:peerCompat",
    "@tanstack/angular-query-experimental": ">=5.95.0",
    "schema-dts": "catalog:"
  },
  "peerDependenciesMeta": {
    "@angular/platform-server": {
      "optional": true
    },
    "@tanstack/angular-query-experimental": {
      "optional": true
    },
    "schema-dts": {
      "optional": true
    }
  },
  "dependencies": {
    "@standard-schema/spec": "catalog:",
    "tslib": "^2.0.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "workspace:*"
  },
  "ng-update": {
    "packageGroup": [
      "@analogjs/platform",
      "@analogjs/content",
      "@analogjs/router",
      "@analogjs/storybook-angular",
      "@analogjs/vite-plugin-angular",
      "@analogjs/vite-plugin-nitro",
      "@analogjs/vitest-angular"
    ],
    "migrations": "./migrations/migration.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
