{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "isolatedDeclarations": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "useDefineForClassFields": false,
    "moduleResolution": "bundler",
    "rootDir": ".",
    "composite": false
  },
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/test-setup.ts",
    "oxlint.config.ts",
    "vite.config.lib.ts",
    "vite.config.ts"
  ],
  "include": ["**/*.ts"]
}
