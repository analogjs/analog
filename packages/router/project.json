{
  "name": "router",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/router/src",
  "implicitDependencies": ["vite-plugin-angular"],
  "prefix": "analogjs",
  "tags": ["type:release"],
  "targets": {
    "assert-deps": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/assert-project-dependency.mts router vite-plugin-angular"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["assert-deps", "vite-plugin-angular:build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "commands": [
          "node tools/scripts/build-lib.mts router",
          "node tools/scripts/verify-package-artifacts.mts router"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["build", "^build"]
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "router@"
      }
    }
  }
}
