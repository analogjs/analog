{
  "name": "vite-plugin-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vite-plugin-angular/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build-self": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["angular-compiler:build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build --config packages/vite-plugin-angular/vite.config.lib.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build-self", "vite-plugin-angular-tools:build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "node tools/scripts/verify-package-artifacts.mts vite-plugin-angular"
      }
    },
    "test": {
      "executor": "@nx/vitest:test"
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "vite-plugin-angular@"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/vite-plugin-angular",
        "command": "pnpm exec tsgo --build tsconfig.lib.json --emitDeclarationOnly"
      }
    }
  }
}
