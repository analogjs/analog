{
  "name": "vite-plugin-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vite-plugin-angular/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build-package": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/vite-plugin-angular"],
      "options": {
        "commands": [
          "vite build --config packages/vite-plugin-angular/vite.config.lib.ts",
          "tsc -p packages/vite-plugin-angular/tsconfig.lib.json --declaration --emitDeclarationOnly --declarationDir node_modules/@analogjs/vite-plugin-angular --rootDir packages/vite-plugin-angular"
        ],
        "parallel": false
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/vite-plugin-angular"],
      "options": {
        "commands": [
          "nx build-package vite-plugin-angular",
          "nx build vite-plugin-angular-tools"
        ],
        "parallel": false
      },
      "dependsOn": ["^build"]
    },
    "test": {
      "executor": "@nx/vitest:test"
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "vite-plugin-angular@"
      }
    }
  }
}
