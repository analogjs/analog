{
  "name": "vite-plugin-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vite-plugin-angular/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "commands": [
          "vite build --config packages/vite-plugin-angular/vite.config.lib.ts",
          "nx build vite-plugin-angular-tools",
          "node tools/scripts/verify-package-artifacts.mts vite-plugin-angular"
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "@nx/vitest:test"
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "vite-plugin-angular@"
      }
    }
  }
}
