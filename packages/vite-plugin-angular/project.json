{
  "name": "vite-plugin-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vite-plugin-angular/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/vite-plugin-angular"],
      "options": {
        "commands": [
          "vite build packages/vite-plugin-angular",
          "tsc --project packages/vite-plugin-angular/tsconfig.lib.json --emitDeclarationOnly --rootDir packages/vite-plugin-angular --outDir node_modules/@analogjs/vite-plugin-angular",
          "node tools/scripts/copy-src-assets.mts packages/vite-plugin-angular node_modules/@analogjs/vite-plugin-angular --assets package.json --dirs migrations",
          "nx build vite-plugin-angular-tools",
          "node tools/scripts/verify-package-artifacts.mts vite-plugin-angular"
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "@nx/vitest:test"
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "vite-plugin-angular@"
      }
    }
  }
}
