{
  "name": "@analogjs/platform",
  "version": "3.0.0-alpha.30",
  "description": "The fullstack meta-framework for Angular",
  "type": "module",
  "author": "Brandon Roberts <robertsbt@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./style-pipeline": {
      "types": "./dist/src/style-pipeline.d.ts",
      "import": "./dist/src/style-pipeline.js",
      "default": "./dist/src/style-pipeline.js"
    },
    "./style-preprocessor": {
      "types": "./dist/src/style-preprocessor.d.ts",
      "import": "./dist/src/style-preprocessor.js",
      "default": "./dist/src/style-preprocessor.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "angular",
    "vite",
    "plugin-vite",
    "meta-framework"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/analogjs/analog/issues"
  },
  "homepage": "https://analogjs.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/analogjs/analog.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/brandonroberts"
  },
  "dependencies": {
    "front-matter": "catalog:",
    "es-toolkit": "catalog:",
    "tinyglobby": "catalog:",
    "nitro": "catalog:",
    "@analogjs/vite-plugin-angular": "workspace:*",
    "@analogjs/vite-plugin-nitro": "workspace:*",
    "rolldown": "catalog:",
    "obug": "catalog:",
    "vitefu": "catalog:"
  },
  "peerDependencies": {
    "@nx/angular": "catalog:peerCompat",
    "@nx/devkit": "catalog:peerCompat",
    "@nx/vite": "catalog:peerCompat",
    "marked": "catalog:",
    "marked-gfm-heading-id": "catalog:",
    "marked-highlight": "catalog:",
    "marked-mangle": "catalog:",
    "marked-shiki": "catalog:",
    "shiki": "catalog:",
    "vite": "catalog:peerCompat"
  },
  "peerDependenciesMeta": {
    "@nx/angular": {
      "optional": true
    },
    "@nx/devkit": {
      "optional": true
    },
    "@nx/vite": {
      "optional": true
    },
    "shiki": {
      "optional": true
    },
    "marked-shiki": {
      "optional": true
    },
    "prismjs": {
      "optional": true
    },
    "marked-highlight": {
      "optional": true
    }
  },
  "builders": "./dist/src/lib/nx-plugin/builders.json",
  "executors": "./dist/src/lib/nx-plugin/executors.json",
  "generators": "./dist/src/lib/nx-plugin/generators.json",
  "schematics": "./dist/src/lib/nx-plugin/generators.json",
  "ng-update": {
    "packageGroup": [
      "@analogjs/platform",
      "@analogjs/content",
      "@analogjs/router",
      "@analogjs/storybook-angular",
      "@analogjs/vite-plugin-angular",
      "@analogjs/vite-plugin-nitro",
      "@analogjs/vitest-angular",
      "@analogjs/angular-compiler"
    ],
    "migrations": "./migrations/migration.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
