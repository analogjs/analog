{
  "name": "platform",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/platform/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/platform"],
      "dependsOn": ["vite-plugin-angular:build", "vite-plugin-nitro:build"],
      "options": {
        "commands": [
          "vite build packages/platform",
          "tsc --project packages/platform/tsconfig.lib.prod.json --emitDeclarationOnly --rootDir packages/platform --outDir node_modules/@analogjs/platform",
          "node tools/scripts/copy-src-assets.mts packages/platform node_modules/@analogjs/platform --assets package.json --dirs migrations",
          "nx build nx-plugin"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["vite-plugin-angular:build", "vite-plugin-nitro:build"]
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "platform@"
      }
    }
  }
}
