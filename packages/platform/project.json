{
  "name": "platform",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/platform/src",
  "projectType": "library",
  "tags": ["type:release"],
  "implicitDependencies": [
    "style-pipeline",
    "vite-plugin-angular",
    "vite-plugin-nitro"
  ],
  "targets": {
    "build-self": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": [
        "style-pipeline:build",
        "vite-plugin-angular:build",
        "vite-plugin-nitro:build"
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "commands": [
          "vite build -c packages/platform/vite.config.lib.ts",
          "node tools/scripts/debug-nx-project-graph.mts nx-plugin"
        ],
        "parallel": false
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build-self", "nx-plugin:build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "node tools/scripts/verify-package-artifacts.mts platform"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["vite-plugin-angular:build", "vite-plugin-nitro:build"]
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "platform@"
      }
    }
  }
}
