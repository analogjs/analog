{
  "name": "style-pipeline",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/style-pipeline/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build-self": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build -c packages/style-pipeline/vite.config.lib.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build-self"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "node tools/scripts/verify-package-artifacts.mts style-pipeline"
      }
    },
    "test": {
      "executor": "@nx/vitest:test"
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "style-pipeline@"
      }
    }
  }
}
