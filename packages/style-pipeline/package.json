{
  "name": "@analogjs/style-pipeline",
  "version": "3.0.0-alpha.25",
  "description": "Shared style pipeline primitives for AnalogJS packages",
  "type": "module",
  "author": "Brandon Roberts <robertsbt@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./style-preprocessor": {
      "types": "./dist/src/style-preprocessor.d.ts",
      "import": "./dist/src/style-preprocessor.js",
      "require": "./dist/src/style-preprocessor.js",
      "default": "./dist/src/style-preprocessor.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "analog",
    "vite",
    "plugin-vite",
    "styles"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/analogjs/analog/issues"
  },
  "homepage": "https://analogjs.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/analogjs/analog.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/brandonroberts"
  },
  "peerDependencies": {
    "vite": "catalog:peerCompat"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
