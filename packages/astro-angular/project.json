{
  "name": "astro-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/astro-angular/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["vite-plugin-angular:build"],
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/astro-angular"],
      "options": {
        "commands": [
          "vite build packages/astro-angular",
          "tsc --project packages/astro-angular/tsconfig.lib.json --emitDeclarationOnly --rootDir packages/astro-angular --outDir node_modules/@analogjs/astro-angular",
          "node tools/scripts/copy-src-assets.mts packages/astro-angular node_modules/@analogjs/astro-angular --assets package.json --dirs migrations",
          "node tools/scripts/verify-package-artifacts.mts astro-angular"
        ],
        "parallel": false
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/publish.mts astro-angular {args.ver} {args.tag}"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test"
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "astro-angular@"
      }
    }
  }
}
