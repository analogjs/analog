{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "preserve",
    "types": ["node", "vitest/globals"],
    "moduleResolution": "bundler",
    "isolatedModules": true
  },
  "files": ["src/test-setup.ts"],
  "include": [
    "**/*.test.ts",
    "**/*.test.mts",
    "**/*.spec.ts",
    "**/*.spec.mts",
    "**/*.d.ts"
  ]
}
