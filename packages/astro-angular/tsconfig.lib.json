{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "isolatedDeclarations": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],
    "paths": {
      "@analogjs/vite-plugin-angular": [
        "../../packages/vite-plugin-angular/src/index.ts",
        "../../packages/vite-plugin-angular/dist"
      ]
    },
    "composite": false
  },
  "include": ["**/*.ts"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "vite.config.ts",
    "src/test-setup.ts",
    "oxlint.config.ts"
  ]
}
