{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "isolatedDeclarations": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": []
  },
  "include": ["**/*.ts"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "vite.config.ts",
    "src/test-setup.ts",
    "oxlint.config.ts"
  ]
}
