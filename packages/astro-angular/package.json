{
  "name": "@analogjs/astro-angular",
  "version": "3.0.0-alpha.23",
  "description": "Use Angular components within Astro",
  "type": "module",
  "author": "Brandon Roberts <robertsbt@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./utils": {
      "types": "./dist/src/utils.d.ts",
      "default": "./dist/src/utils.js"
    },
    "./client.js": {
      "types": "./dist/src/client.d.ts",
      "default": "./dist/src/client.js"
    },
    "./server.js": {
      "types": "./dist/src/server.d.ts",
      "default": "./dist/src/server.js"
    },
    "./middleware": {
      "types": "./dist/src/middleware.d.ts",
      "default": "./dist/src/middleware.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "angular",
    "astro",
    "astro-integration",
    "astro-component",
    "renderer"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/analogjs/analog/issues"
  },
  "homepage": "https://analogjs.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/analogjs/analog.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/brandonroberts"
  },
  "dependencies": {
    "@analogjs/vite-plugin-angular": "workspace:*",
    "rehype": "^13.0.2"
  },
  "peerDependencies": {
    "@angular/build": "catalog:peerAngular20Plus",
    "@angular/animations": "catalog:peerAngular20Plus",
    "@angular/common": "catalog:peerAngular20Plus",
    "@angular/compiler-cli": "catalog:peerAngular20Plus",
    "@angular/compiler": "catalog:peerAngular20Plus",
    "@angular/core": "catalog:peerAngular20Plus",
    "@angular/language-service": "catalog:peerAngular20Plus",
    "@angular/platform-browser": "catalog:peerAngular20Plus",
    "@angular/platform-server": "catalog:peerAngular20Plus",
    "rxjs": "catalog:peerAngular20Plus",
    "tslib": "catalog:peerAngular20Plus",
    "vite": "catalog:peerCompat"
  },
  "ng-update": {
    "packageGroup": [
      "@analogjs/platform",
      "@analogjs/content",
      "@analogjs/router",
      "@analogjs/storybook-angular",
      "@analogjs/vite-plugin-angular",
      "@analogjs/vite-plugin-nitro",
      "@analogjs/vitest-angular"
    ],
    "migrations": "./migrations/migration.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
