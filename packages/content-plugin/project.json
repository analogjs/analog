{
  "name": "content-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/content-plugin/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["content:build-self"],
      "outputs": ["{workspaceRoot}/packages/content/dist/plugin"],
      "options": {
        "command": "tsdown -c packages/content-plugin/tsdown.config.ts --config-loader unrun"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test"
    }
  }
}
