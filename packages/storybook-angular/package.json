{
  "name": "@analogjs/storybook-angular",
  "version": "3.0.0-alpha.25",
  "description": "Storybook Integration for Angular & Vite",
  "type": "module",
  "keywords": [
    "storybook",
    "angular",
    "vite"
  ],
  "homepage": "https://analogjs.org",
  "bugs": {
    "url": "https://github.com/analogjs/analog/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/analogjs/analog.git",
    "directory": "packages/storybook-angular"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/brandonroberts"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./preset": "./dist/preset.js",
    "./package.json": "./package.json",
    "./testing": {
      "types": "./dist/src/lib/testing.d.ts",
      "default": "./dist/src/lib/testing.js"
    }
  },
  "main": "dist/src/index.js",
  "dependencies": {
    "@storybook/builder-vite": "catalog:peerStorybook10",
    "obug": "catalog:"
  },
  "peerDependencies": {
    "@storybook/angular": "catalog:peerStorybook10",
    "@analogjs/vite-plugin-angular": "catalog:peerVitestAngular",
    "storybook": "catalog:peerStorybook10",
    "vite": "catalog:peerCompat"
  },
  "engines": {
    "node": ">=22.18.0 || >=24.3.0"
  },
  "builders": "./dist/src/lib/builders.json",
  "ng-add": {
    "save": "devDependencies"
  },
  "ng-update": {
    "packageGroup": [
      "@analogjs/platform",
      "@analogjs/content",
      "@analogjs/router",
      "@analogjs/storybook-angular",
      "@analogjs/vite-plugin-angular",
      "@analogjs/vite-plugin-nitro",
      "@analogjs/vitest-angular"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
