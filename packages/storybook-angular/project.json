{
  "name": "storybook-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build", "vite-plugin-angular:build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "commands": [
          "vite build -c packages/storybook-angular/vite.config.lib.ts",
          "node tools/scripts/verify-package-artifacts.mts storybook-angular"
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["vite-plugin-angular:build", "vitest-angular:build"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/storybook-angular",
        "command": "pnpm exec tsgo --build tsconfig.lib.json --emitDeclarationOnly"
      }
    }
  }
}
