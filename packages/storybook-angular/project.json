{
  "name": "storybook-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["vite-plugin-angular:build"],
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/storybook-angular"],
      "options": {
        "commands": [
          "vite build packages/storybook-angular",
          "tsc --project packages/storybook-angular/tsconfig.lib.json --emitDeclarationOnly --rootDir packages/storybook-angular --outDir node_modules/@analogjs/storybook-angular",
          "node tools/scripts/copy-src-assets.mts packages/storybook-angular node_modules/@analogjs/storybook-angular --assets package.json preset.js --src",
          "node tools/scripts/verify-package-artifacts.mts storybook-angular"
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["vite-plugin-angular:build"]
    }
  }
}
