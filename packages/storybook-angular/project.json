{
  "name": "storybook-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["type:release"],
  "implicitDependencies": ["vite-plugin-angular"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/storybook-angular"],
      "options": {
        "command": "vite build -c packages/storybook-angular/vite.config.lib.ts"
      }
    },
    "test": {
      "dependsOn": ["^build"],
      "executor": "@nx/vitest:test"
    }
  }
}
