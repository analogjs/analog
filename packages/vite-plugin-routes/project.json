{
  "name": "vite-plugin-routes",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vite-plugin-routes/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/vite-plugin-routes"],
      "options": {
        "command": "vite build -c packages/vite-plugin-routes/vite.config.lib.ts"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["build", "^build"],
      "options": {
        "passWithNoTests": true
      }
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "vite-plugin-routes@"
      }
    }
  }
}
