{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": ["node"],
    "target": "ES2022",
    "useDefineForClassFields": false,
    "moduleResolution": "bundler"
  },
  "exclude": ["**/*.spec.ts"],
  "include": ["**/*.ts"]
}
