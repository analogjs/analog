{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/docs/vite/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/docs"],
      "dependsOn": ["^build"],
      "options": {
        "parallel": false,
        "commands": [
          "nx run docs:build-vite",
          "node packages/docs/scripts/write-package-json.mjs"
        ]
      }
    },
    "build-vite": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/docs/vite"],
      "options": {
        "command": "tsc -p packages/docs/vite/tsconfig.json"
      }
    }
  }
}
