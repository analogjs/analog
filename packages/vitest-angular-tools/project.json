{
  "name": "vitest-angular-tools",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vitest-angular-tools/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/node_modules/@analogjs/vitest-angular/src/lib/tools"
      ],
      "options": {
        "command": "vite build -c packages/vitest-angular-tools/vite.config.lib.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["vitest-angular:build"]
    }
  }
}
