{
  "name": "vitest-angular-tools",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vitest-angular-tools/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/vitest-angular-tools"],
      "options": {
        "commands": [
          "vite build packages/vitest-angular-tools",
          "tsc --project packages/vitest-angular-tools/tsconfig.lib.json --emitDeclarationOnly --rootDir packages/vitest-angular-tools --outDir dist/packages/vitest-angular-tools",
          "node tools/scripts/copy-src-assets.mts packages/vitest-angular-tools dist/packages/vitest-angular-tools --assets package.json collection.json --src"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["build"]
    }
  }
}
