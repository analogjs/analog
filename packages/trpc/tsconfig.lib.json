{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "isolatedDeclarations": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": ["node"],
    "moduleResolution": "bundler",
    "rootDir": "."
  },
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/test-setup.ts",
    "vite.config.lib.ts"
  ],
  "include": ["src/**/*.ts", "server/src/**/*.ts"]
}
