{
  "name": "vitest-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vitest-angular/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build-package": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/vitest-angular"],
      "options": {
        "commands": [
          "vite build --config packages/vitest-angular/vite.config.lib.ts",
          "tsc -p packages/vitest-angular/tsconfig.lib.json --declaration --emitDeclarationOnly --declarationDir node_modules/@analogjs/vitest-angular --rootDir packages/vitest-angular"
        ],
        "parallel": false
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/vitest-angular"],
      "options": {
        "commands": [
          "nx build-package vitest-angular",
          "nx build vitest-angular-tools"
        ],
        "parallel": false
      },
      "dependsOn": ["^build"]
    }
  }
}
