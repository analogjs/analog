{
  "name": "vitest-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vitest-angular/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "commands": [
          "vite build --config packages/vitest-angular/vite.config.lib.ts",
          "vite build -c packages/vitest-angular-tools/vite.config.lib.ts",
          "node tools/scripts/verify-package-artifacts.mts vitest-angular"
        ],
        "parallel": false
      }
    }
  }
}
