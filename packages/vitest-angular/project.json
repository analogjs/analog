{
  "name": "vitest-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vitest-angular/src",
  "projectType": "library",
  "tags": ["type:release"],
  "targets": {
    "build-package": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "node_modules/@analogjs/vitest-angular",
        "main": "packages/vitest-angular/src/index.ts",
        "tsConfig": "packages/vitest-angular/tsconfig.lib.json",
        "assets": [
          "packages/vitest-angular/*.md",
          "packages/vitest-angular/builders.json"
        ],
        "updateBuildableProjectDepsInPackageJson": false,
        "additionalEntryPoints": [
          "packages/vitest-angular/setup-zone.ts",
          "packages/vitest-angular/setup-snapshots.ts",
          "packages/vitest-angular/setup-serializers.ts",
          "packages/vitest-angular/snapshot-serializers.ts",
          "packages/vitest-angular/setup-testbed.ts"
        ],
        "generateExportsField": true
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/vitest-angular"],
      "options": {
        "commands": [
          "nx build-package vitest-angular",
          "nx build vitest-angular-tools"
        ],
        "parallel": false
      },
      "dependsOn": ["^build"]
    },
    "test": {
      "executor": "@nx/vitest:test"
    }
  }
}
