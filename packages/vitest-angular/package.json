{
  "name": "@analogjs/vitest-angular",
  "version": "3.0.0-alpha.41",
  "description": "Vitest Builder for Angular",
  "type": "module",
  "author": "Brandon Roberts <robertsbt@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./setup-zone": {
      "types": "./dist/setup-zone.d.ts",
      "default": "./dist/setup-zone.js"
    },
    "./setup-snapshots": {
      "types": "./dist/setup-snapshots.d.ts",
      "default": "./dist/setup-snapshots.js"
    },
    "./setup-serializers": {
      "types": "./dist/setup-serializers.d.ts",
      "default": "./dist/setup-serializers.js"
    },
    "./setup-testbed": {
      "types": "./dist/setup-testbed.d.ts",
      "default": "./dist/setup-testbed.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "angular",
    "vite",
    "vitest",
    "meta-framework"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/analogjs/analog/issues"
  },
  "homepage": "https://analogjs.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/analogjs/analog.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/brandonroberts"
  },
  "builders": "./dist/builders.json",
  "schematics": "./dist/src/lib/tools/collection.json",
  "ng-add": {
    "save": "devDependencies"
  },
  "dependencies": {
    "oxc-transform": "catalog:"
  },
  "peerDependencies": {
    "@analogjs/vite-plugin-angular": "catalog:peerVitestAngular",
    "@angular-devkit/architect": "catalog:peerVitestAngular",
    "@angular-devkit/schematics": "catalog:peerVitestAngular",
    "vitest": "catalog:peerVitestAngular",
    "zone.js": "catalog:peerVitestAngular"
  },
  "peerDependenciesMeta": {
    "zone.js": {
      "optional": true
    }
  },
  "ng-update": {
    "packageGroup": [
      "@analogjs/platform",
      "@analogjs/content",
      "@analogjs/router",
      "@analogjs/storybook-angular",
      "@analogjs/vite-plugin-angular",
      "@analogjs/vite-plugin-nitro",
      "@analogjs/vitest-angular"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
