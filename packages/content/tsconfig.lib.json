{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],
    "isolatedDeclarations": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@analogjs/content": ["./src/index.ts"],
      "@analogjs/content/*": ["./*"]
    }
  },
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "vite.config.ts",
    "vite.config.lib.ts"
  ],
  "include": ["**/*.ts"]
}
