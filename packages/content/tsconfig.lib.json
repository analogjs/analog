{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],
    "isolatedDeclarations": true,
    "rootDir": ".",
    "composite": false
  },
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/test-setup.ts",
    "oxlint.config.ts",
    "vite.config.lib.ts",
    "vite.config.ts"
  ],
  "include": ["**/*.ts"]
}
