{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "target": "es2020",
    "lib": ["es2022"],
    "types": ["node"],
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../../../../node_modules/@analogjs/content/docs/vite",
    "rootDir": "./src"
  },
  "include": ["src/**/*.ts"]
}
