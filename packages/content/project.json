{
  "name": "content",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/content/src",
  "implicitDependencies": ["vite-plugin-angular"],
  "prefix": "analogjs",
  "tags": ["type:release"],
  "targets": {
    "assert-deps": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/assert-project-dependency.mts content vite-plugin-angular"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["assert-deps", "vite-plugin-angular:build"],
      "outputs": ["{workspaceRoot}/node_modules/@analogjs/content"],
      "options": {
        "commands": [
          "node tools/scripts/build-lib.mts content",
          "nx build content-plugin",
          "node tools/scripts/verify-package-artifacts.mts content"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["build"]
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "content@"
      }
    }
  }
}
