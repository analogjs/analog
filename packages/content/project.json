{
  "name": "content",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/content/src",
  "implicitDependencies": ["vite-plugin-angular"],
  "prefix": "analogjs",
  "tags": ["type:release"],
  "targets": {
    "assert-deps": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/assert-project-dependency.mts content build-self angular-compiler:build vite-plugin-angular:build"
      }
    },
    "build-self": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": [
        "assert-deps",
        "angular-compiler:build",
        "vite-plugin-angular:build"
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "node tools/scripts/build-lib.mts content"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build-self", "content-plugin:build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "node tools/scripts/verify-package-artifacts.mts content"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "dependsOn": ["build"]
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "tagPrefix": "content@"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/content",
        "command": "pnpm exec tsgo --build tsconfig.lib.json --emitDeclarationOnly"
      }
    }
  }
}
